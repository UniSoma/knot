{:paths ["src"]
 ;; All non-bb dependencies (clj-yaml, cheshire, flatland.ordered.map) ship
 ;; bundled with babashka, so no :deps declaration is required at runtime.
 ;; The minimum version below is a conservative floor — it covers the bb
 ;; releases where babashka.cli is present and the bundled dep surface used
 ;; here (ordered-map iteration, clj-yaml ordered preservation) is stable.
 :min-bb-version "1.3.0"

 ;; bbin install metadata. `bbin install <coords> --as knot` reads this
 ;; map and wires up `knot` on PATH to invoke `bb -m knot.main` with the
 ;; project's :paths on the classpath.
 :bbin/bin {knot {:main-opts ["-m" "knot.main"]}}

 :tasks
 {:requires ([babashka.classpath :as cp]
             [babashka.fs :as fs]
             [clojure.string :as str]
             [clojure.test :as t])

  test
  {:doc "Run all tests under test/"
   :task
   (do
     (cp/add-classpath "test")
     (let [nses (->> (fs/glob "test" "**/*_test.clj")
                     (map (fn [p] (str (fs/relativize "test" p))))
                     (map (fn [p] (-> p
                                      (str/replace ".clj" "")
                                      (str/replace "/" ".")
                                      (str/replace "_" "-"))))
                     (map symbol)
                     vec)]
       (if (empty? nses)
         (println "No tests found.")
         (do
           (apply require nses)
           (let [{:keys [fail error]} (apply t/run-tests nses)]
             (when (pos? (+ fail error))
               (System/exit 1)))))))}

  knot
  {:doc "Run the knot CLI"
   :task (do
           (require '[knot.main])
           (apply (resolve 'knot.main/-main) *command-line-args*))}}}
